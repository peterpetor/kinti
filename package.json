{
  "name": "kinti",
  "version": "0.1.0",
  "private": true,
  "description": "Találj magyart a közeledben — GPS-alapú magyar szakemberkereső PWA (Cloudflare Pages + Next.js).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "pages:build": "node scripts/pages-build.mjs",
    "pages:build:win": "powershell -NoProfile -File build-pages.ps1",
    "preview": "npm run pages:build && wrangler pages dev",
    "deploy": "npm run pages:build && wrangler pages deploy --branch main",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./env.d.ts",
    "db:migrate:local": "wrangler d1 migrations apply kinti-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply kinti-db --remote",
    "db:seed:local": "wrangler d1 execute kinti-db --local --file=./db/seed.sql",
    "db:seed:remote": "wrangler d1 execute kinti-db --remote --file=./db/seed.sql",
    "gen:icons": "node scripts/gen-icons.mjs"
  },
  "dependencies": {
    "@clerk/localizations": "^4.6.8",
    "@clerk/nextjs": "^7.4.1",
    "@types/leaflet.markercluster": "^1.5.6",
    "aws4fetch": "^1.0.20",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "maplibre-gl": "^5.24.0",
    "next": "14.2.29",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-leaflet": "^4.2.1",
    "react-leaflet-cluster": "^4.1.3",
    "resend": "^4.8.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.7",
    "@cloudflare/workers-types": "^4.20241112.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.16.13",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "postcss": "^8.4.47",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vercel": "^37.14.0",
    "vitest": "^4.1.7",
    "wrangler": "^4.95.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
