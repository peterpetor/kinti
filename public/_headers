# Cloudflare Pages — globális security + útvonal-specifikus HTTP fejlécek.
# Doc: https://developers.cloudflare.com/pages/configuration/headers/

# --- Minden válaszra: alap security headerek -------------------------------
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Permissions-Policy: camera=(), microphone=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com https://challenges.cloudflare.com https://clerk.kinti.app; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://*.cloudflareinsights.com https://*.clerk.accounts.dev https://clerk.kinti.app https://api.frankfurter.app https://geocoding-api.open-meteo.com https://api.open-meteo.com https://*.basemaps.cartocdn.com https://challenges.cloudflare.com; worker-src 'self' blob:; frame-src https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests

# --- Manage-page-ek: szigorúbb referrer-policy hogy a token ne szivárogjon
/szaknevsor/kezeles/*
  Referrer-Policy: no-referrer
/hirdetes-kezeles/*
  Referrer-Policy: no-referrer
/esemeny-kezeles/*
  Referrer-Policy: no-referrer
/spontan-kezeles/*
  Referrer-Policy: no-referrer
/velemeny-kezeles/*
  Referrer-Policy: no-referrer

# --- PWA-érzékeny fájlok ---------------------------------------------------
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
  Service-Worker-Allowed: /

/manifest.webmanifest
  Cache-Control: public, max-age=300
  Content-Type: application/manifest+json; charset=utf-8

/icons/*
  Cache-Control: public, max-age=31536000, immutable

/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

/offline
  Cache-Control: public, max-age=0, must-revalidate
